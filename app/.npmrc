; Expo's `expo install --fix` pinned react@19.2.0 (the SDK-55 alignment) but
; react-test-renderer@19.2.3 (devDependency) peer-requires react@^19.2.3.
; Standard pattern for Expo monorepos: allow npm to resolve through the
; mismatch instead of failing the EAS "Install dependencies" phase.
legacy-peer-deps=true
