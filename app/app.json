{
  "name": "LiveStylist",
  "displayName": "LiveStylist",
  "expo": {
    "name": "LiveStylist",
    "slug": "livestylist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "livestylist",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f23"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.livestylist.ios",
      "infoPlist": {
        "NSCameraUsageDescription": "LiveStylist uses your camera to analyze your style and provide real-time fashion advice.",
        "NSMicrophoneUsageDescription": "LiveStylist uses your microphone for voice conversations with your AI stylist.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.livestylist",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f23"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "enableLocation": false
        }
      ],
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0f0f23"
        }
      ],
      "@sentry/react-native",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "78cc5a2d-12ee-4164-beee-d52e0715922d"
      }
    },
    "owner": "stgim"
  }
}
