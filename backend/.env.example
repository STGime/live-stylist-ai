# Server
PORT=8080
NODE_ENV=development

# Eurobase (EU-sovereign BaaS — https://eurobase.app)
EUROBASE_URL=https://livestylist.eurobase.app
EUROBASE_SECRET_KEY=eb_sk_your_secret_key

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# Fal.ai (image generation)
FAL_AI_KEY=your-fal-key

# RevenueCat
REVENUECAT_API_KEY=your-revenuecat-secret-key

# Session limits
FREE_SESSIONS_PER_DAY=1
PREMIUM_SESSIONS_PER_DAY=5
SESSION_DURATION_SECONDS=300
SESSION_WARNING_SECONDS=270
